# Incident 2026-05-16 fix. The Docker runtime runs the app from
# /app/dist/quickstart.js and Node resolves bare imports against
# /app/node_modules (walking UP from /app/dist). pnpm's default
# node-linker=isolated leaves each workspace package's deps under
# packages/<pkg>/node_modules (symlinked to .pnpm), which is NOT an
# ancestor of /app/dist → ERR_MODULE_NOT_FOUND for pg/ajv/etc → prod
# CrashLoop. `hoisted` produces a flat, npm-style node_modules at the
# install root so every dependency is resolvable from /app/dist, which
# is exactly what the Dockerfile's COPY /build/node_modules assumes.
#
# Scope: only affects the monorepo pnpm install (celiums-memory build).
# atlas-server / tier-classifier have self-contained Dockerfiles using
# `npm install` and are unaffected.
node-linker=hoisted
