{
  "name": "celiums-memory",
  "version": "2.0.0",
  "private": true,
  "description": "Neuroscience-grounded persistent memory for AI agents — with real emotions, personality, and a simulated brain",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrizoaguimor/celiums-memory.git"
  },
  "homepage": "https://celiums.ai",
  "bugs": {
    "url": "https://github.com/terrizoaguimor/celiums-memory/issues"
  },
  "author": {
    "name": "Celiums Solutions LLC",
    "email": "hello@celiums.ai",
    "url": "https://celiums.ai"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "start": "tsx packages/core/src/quickstart.ts",
    "setup": "pnpm build && pnpm start",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:build": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "ethics:load": "node scripts/load-ethics-knowledge.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.5.4",
      "fast-uri": ">=3.1.2",
      "@opentelemetry/exporter-prometheus": ">=0.217.0",
      "@opentelemetry/sdk-node": ">=0.217.0",
      "langsmith": ">=0.6.0",
      "ip-address": ">=10.1.1"
    }
  }
}
