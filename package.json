{
  "name": "celiums-memory",
  "version": "1.0.0",
  "private": true,
  "description": "Neuroscience-grounded persistent memory for AI agents — with real emotions, personality, and a simulated brain",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrizoaguimor/celiums-memory.git"
  },
  "homepage": "https://celiums.ai",
  "bugs": {
    "url": "https://github.com/terrizoaguimor/celiums-memory/issues"
  },
  "author": {
    "name": "Celiums Solutions LLC",
    "email": "hello@celiums.ai",
    "url": "https://celiums.ai"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "start": "tsx packages/core/src/quickstart.ts",
    "setup": "pnpm run build:knowledge && pnpm start",
    "build:knowledge": "cd packages/knowledge-types && npx tsc && cd ../knowledge && npx tsc && cd ../types && npx tsup src/index.ts --format esm,cjs --dts --clean",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:build": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "db:migrate": "turbo run db:migrate --filter=@celiums/server",
    "db:seed": "turbo run db:seed --filter=@celiums/server",
    "db:reset": "turbo run db:reset --filter=@celiums/server"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.5.4"
    }
  }
}