{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://celiums.ai/schemas/v1/common/uuid.schema.json",
  "title": "uuid",
  "description": "RFC 4122 UUID (any version). Used wherever a row id appears in tool inputs.",
  "type": "string",
  "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
}
