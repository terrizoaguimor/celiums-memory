# ─────────────────────────────────────────────
#  Celiums Memory — Environment Configuration
#  Copy this file to docker/.env and fill in values
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
CELIUMS_VERSION=latest
CELIUMS_PORT=3456
CELIUMS_API_KEY=change-me-to-a-secure-random-string
CELIUMS_LOG_LEVEL=info
CELIUMS_CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=celiums
POSTGRES_PASSWORD=celiums_secret_change_me
POSTGRES_DB=celiums_memory

# ── Qdrant ────────────────────────────────────
QDRANT_API_KEY=
QDRANT_COLLECTION=celiums_memories
QDRANT_LOG_LEVEL=INFO

# ── Valkey ────────────────────────────────────
VALKEY_PASSWORD=valkey_secret_change_me
VALKEY_MAX_MEMORY=256mb
VALKEY_LOG_LEVEL=notice

# ── Embeddings ────────────────────────────────
# Options: openai | ollama | cohere | local
EMBEDDINGS_PROVIDER=openai

# OpenAI (if EMBEDDINGS_PROVIDER=openai)
OPENAI_API_KEY=sk-...
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIMENSIONS=1536

# Ollama (if EMBEDDINGS_PROVIDER=ollama — fully local!)
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Cohere (if EMBEDDINGS_PROVIDER=cohere)
# COHERE_API_KEY=...

# ── Memory Settings ───────────────────────────
MEMORY_MAX_PER_AGENT=10000
MEMORY_SIMILARITY_THRESHOLD=0.75
MEMORY_CACHE_TTL_SECONDS=300

# ── MCP ───────────────────────────────────────
MCP_ENABLED=true
MCP_PATH=/mcp