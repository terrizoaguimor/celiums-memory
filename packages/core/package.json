{
  "name": "@celiums/memory",
  "version": "2.0.0",
  "description": "Neuroscience-grounded persistent memory for AI agents — with real emotions, personality, and a simulated brain. 3 layers, 15 modules, 10 equations. SQLite, in-memory, or full triple-store.",
  "keywords": [
    "ai",
    "memory",
    "llm",
    "emotional-ai",
    "neuroscience",
    "cognitive-architecture",
    "personality",
    "agent-memory",
    "persistent-memory",
    "langchain",
    "llamaindex",
    "mcp",
    "pad-model",
    "big-five",
    "limbic-system",
    "typescript",
    "sqlite"
  ],
  "homepage": "https://celiums.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrizoaguimor/celiums-memory.git",
    "directory": "packages/core"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Celiums Solutions LLC",
    "email": "hello@celiums.ai",
    "url": "https://celiums.ai"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./store": {
      "import": {
        "types": "./dist/store.d.ts",
        "default": "./dist/store.js"
      }
    },
    "./store-sqlite": {
      "import": {
        "types": "./dist/store-sqlite.d.ts",
        "default": "./dist/store-sqlite.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/store.ts src/store-sqlite.ts src/quickstart.ts --format esm --dts --clean --sourcemap --external better-sqlite3 --external pg --external @qdrant/js-client-rest --external ioredis",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@celiums/memory-types": "workspace:*",
    "@celiums/types": "^0.1.1",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/aws": "^1.3.5",
    "@langchain/core": "^1.1.44",
    "@langchain/deepseek": "^1.0.25",
    "@langchain/google-genai": "^2.1.28",
    "@langchain/google-vertexai": "^2.1.28",
    "@langchain/mistralai": "^1.0.8",
    "@langchain/openai": "^1.4.5",
    "@langchain/xai": "^1.3.17",
    "@qdrant/js-client-rest": "^1.17.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cohere-ai": "^8.0.0",
    "ioredis": "^5.10.1",
    "jose": "^5.10.0",
    "maxmind": "^4.3.29",
    "ollama": "^0.5.18",
    "pg": "^8.20.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
