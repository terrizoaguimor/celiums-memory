# ─────────────────────────────────────────────────────────
#  Celiums — Environment Configuration
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Core (required for triple-store mode) ─────────────────
DATABASE_URL=postgresql://celiums:YOUR_PASSWORD@localhost:5432/celiums_memory
QDRANT_URL=http://localhost:6333
VALKEY_URL=redis://localhost:6379
PORT=3210

# ── Auth ──────────────────────────────────────────────────
# Auto-generated on first run if not set. Save it!
# CELIUMS_API_KEY=cmk_...

# ── Personality ───────────────────────────────────────────
PERSONALITY=celiums

# ── SQLite mode (alternative to triple-store) ─────────────
# Set SQLITE_PATH instead of DATABASE_URL for single-file mode
# SQLITE_PATH=./celiums.db

# ── Knowledge engine (optional, connects to modules DB) ───
# KNOWLEDGE_DATABASE_URL=postgresql://celiums:YOUR_PASSWORD@localhost:5432/celiums

# ── Embeddings ────────────────────────────────────────────
# EMBEDDING_URL=http://localhost:8080/embed
# EMBEDDING_MODEL=nomic-embed-text-v2
# EMBEDDING_DIM=384

# ── Fleet (optional, enables 8 AI-powered tools) ─────────
# Get your key from DigitalOcean Gradient or any OpenAI-compatible API
# CELIUMS_FLEET_API_KEY=sk-...

# ── Atlas (optional, enables collaboration + cloud sync) ──
# Get your key from atlas.celiums.ai
# CELIUMS_ATLAS_API_KEY=cmk_...
