# ─────────────────────────────────────────────────────────
#  Celiums — Environment Configuration
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Docker infrastructure passwords ──────────────────────
POSTGRES_PASSWORD=change_me_to_something_secure
VALKEY_PASSWORD=change_me_to_something_secure

# ── Core ─────────────────────────────────────────────────
DATABASE_URL=postgresql://celiums:${POSTGRES_PASSWORD}@localhost:5432/celiums_memory
QDRANT_URL=http://localhost:6333
VALKEY_URL=redis://:${VALKEY_PASSWORD}@localhost:6379
PORT=3210

# ── Knowledge engine (5,100 modules) ─────────────────────
KNOWLEDGE_DATABASE_URL=postgresql://celiums:${POSTGRES_PASSWORD}@localhost:5432/celiums

# ── Auth ─────────────────────────────────────────────────
# Auto-generated on first run if not set
# CELIUMS_API_KEY=cmk_...

# ── Personality ──────────────────────────────────────────
PERSONALITY=celiums

# ── Onboarding (auto-creates user profile on first run) ──
# CELIUMS_USER_NAME=your_name
# CELIUMS_LANGUAGE=en
# CELIUMS_TIMEZONE=America/New_York
# CELIUMS_CHRONOTYPE=neutral

# ── SQLite mode (alternative — no Docker needed) ─────────
# Uncomment this and comment out DATABASE_URL for single-file mode
# SQLITE_PATH=./celiums.db

# ── Fleet (optional, enables 8 AI-powered tools) ─────────
# CELIUMS_FLEET_API_KEY=sk-...

# ── Atlas (optional, enables collaboration) ──────────────
# CELIUMS_ATLAS_API_KEY=cmk_...

# ── Cloudflare Tunnel (optional, expose to internet) ─────
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token
